{
  "name": "@alexanderfortin/pi-token-usage",
  "author": "Alexander Fortin",
  "version": "0.2.0",
  "description": "Pi coding agent extension for analyzing token usage and cost across session files",
  "keywords": [
    "pi-package",
    "token-usage",
    "cost-tracking",
    "session-analysis"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "MIT",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "0.75.3",
    "@earendil-works/pi-tui": "0.75.3",
    "@sinclair/typebox": "^0.34.49"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shaftoe/pi-token-usage"
  },
  "scripts": {
    "build": "bun run check && tsc --project tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint ./",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "validate": "bun run check && bun run lint && bun run format:check",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "devDependencies": {
    "@alexanderfortin/semantic-release-keep-a-changelog": "^0.2.1",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "25.9.0",
    "bun-types": "1.3.14",
    "eslint": "10.4.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.4"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  }
}
